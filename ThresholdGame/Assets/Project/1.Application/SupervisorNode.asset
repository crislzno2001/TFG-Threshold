  m_Script: {fileID: 11500000, guid: d9bb417fcb585cc4b80fb00beca23d32, type: 3}
  m_Name: Motivo_Imaginacion_01
  m_EditorClassIdentifier: Assembly-CSharp::OpenAI.Dialogue.SpeechNodeSO
  nodeGuid: c2ae8185-8fed-429a-ae07-90eab20cfcfe
  contextForAI: "Este nodo se activa cuando el jugador pregunta por qu\xE9 los robots
    necesitan imaginaci\xF3n humana o cuando se resiste al experimento y exige una
    explicaci\xF3n. Supervisor A-13 debe explicar que la crisis actual requiere ideas
    improbables, intuiciones y asociaciones que las m\xE1quinas no generan con facilidad.
    El tono debe seguir siendo fr\xEDo y anal\xEDtico."
  prerequisiteFlags: []
  lockedReply: "A\xFAn no puedes avanzar por aqu\xED."
  flagsOnEnter: []
  nextNodes: []
  openingLine: "Podemos calcular, optimizar y predecir. Pero no inventar del mismo
    modo que vosotros. La crisis exige posibilidades nuevas, y vuestra especie sigue
    produciendo errores creativos que pueden convertirse en soluci\xF3n."
  transitions: []
