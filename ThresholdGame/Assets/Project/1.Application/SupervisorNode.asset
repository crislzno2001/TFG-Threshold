  m_Name: Reaccion_Inicial_01
  m_EditorClassIdentifier: Assembly-CSharp::OpenAI.Dialogue.ChoiceNodeSO
  nodeGuid: a3dfadb3-1afc-47b8-b6ce-8571fcfb747c
  contextForAI: "Este nodo representa la primera reacci\xF3n del jugador al despertar
    en la instalaci\xF3n. Las posibles intenciones del jugador son pedir explicaciones
    sobre el lugar, preguntar por el motivo del experimento o rechazar la situaci\xF3n
    con miedo o desconfianza."
  prerequisiteFlags: []
  lockedReply: "A\xFAn no puedes avanzar por aqu\xED."
  flagsOnEnter: []
  nextNodes: []
  choices:
  - condition: "pregunta donde est\xE1 o que es este lugar "
    nextNode: {fileID: 1372673885765758885}
  - condition: "pregunta por qu\xE9 los robots necesitan imaginaci\xF3n humana "
    nextNode: {fileID: 4908219652613408325}
--- !u!114 &4908219652613408325
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
