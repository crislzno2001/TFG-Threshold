  m_Script: {fileID: 11500000, guid: d9bb417fcb585cc4b80fb00beca23d32, type: 3}
  m_Name: Explicacion_Instalacion_01
  m_EditorClassIdentifier: Assembly-CSharp::OpenAI.Dialogue.SpeechNodeSO
  nodeGuid: 2b22d1c2-b323-4bff-bd8a-3f5db177e928
  contextForAI: "Este nodo se activa cuando el jugador pregunta d\xF3nde est\xE1
    o qu\xE9 es este lugar. Supervisor A-13 debe responder con claridad controlada,
    sin contarlo todo. Debe explicar que se trata de una instalaci\xF3n de evaluaci\xF3n
    cognitiva y sugerir que el sujeto ha sido seleccionado por una capacidad mental
    valiosa."
  prerequisiteFlags: []
  lockedReply: "A\xFAn no puedes avanzar por aqu\xED."
  flagsOnEnter: []
  nextNodes: []
  openingLine: "Te encuentras en una unidad de evaluaci\xF3n cognitiva. Has sido
    conservado porque tu mente puede producir patrones que nuestros sistemas no logran
    originar por s\xED solos."
  transitions: []
